doctype html 
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Chat 
    //- link(rel="stylesheet", href="/public/css/index.css")
    //- link(rel="stylesheet", href="/public/css/zoom.css")
    // 파비콘 추가
    link(rel="icon" type="image/png" href="/public/favicon/favicon-96x96.png")
    //- link(rel="stylesheet", href="https://unpkg.com/mvp.css")
    link(rel="stylesheet", href="public/css/reset.css")
    link(rel="stylesheet", href="public/css/common.css")
    link(rel="stylesheet", href="public/css/layout/welcome.css")
    link(rel="stylesheet", href="public/css/layout/control.css")
    link(rel="stylesheet", href="public/css/layout/chat.css")
    link(rel="stylesheet", href="public/css/elements/button.css")
    link(rel="stylesheet", href="public/css/elements/bubble.css")

  body
    //- h1 It works!
    header 
      h1 채팅 서버
    main 
      div#welcome 
        form.welcome-form(action="") 
          span 방 이름
          //- input(type="text" placeholder="choose a room name..." required autofocus)
          input(type="text" placeholder="room name..." required )
          button Enter Room
        h4 open rooms (방 목록):
        ul#roomList
      
      div#call.call(hidden)
        div#myStream
          div.control
            button#mute Mute 
            button#camera Turn Camera Off
            select#cameraSelect(name="cameraSelect")
          div 
            video#myFace(autoplay , playsinline, width="400" height="400" ) 
            video#peerFace(autoplay , playsinline, width="400" height="400" )

        div.chat 
          ul.chats 
            li example
            li example
          form 
            input(placeholder="Message", required, type="text")
            input(value="Send", required, type="submit")









      //- div#room(style="display: none;")
      div#room(hidden)
        h3
        ul  
        form#name(action="") 
          //- span 방 이름
          input(type="text" placeholder="nickname ..." required)
          button Save 

        form#msg(action="") 
          //- span 방 이름
          input(type="text" placeholder="msg ..." required)
          button Send



      div#websocket(style="display: none;")
        //- h2 Welcome to Chat!
        form#nicknameForm(action="") 
          span 별명
          input(type="text" name="nickname" placeholder="choose a nickname..." required)
          button(type="submit") Save
        ul 
        form#messageForm(action="") 
          span(id="clientId")
          input(type="text" name="message" placeholder="Type a message..." required)
          button(type="submit") Send







  script(src="/socket.io/socket.io.js")
  //- script(src="/public/js/app.js" )
  script(src="/public/js/app.js" type="module")